{
  "name": "nest-postgress",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "license": "UNLICENSED",
  "scripts": {
    "nx": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx",
    "graph": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx graph",
    "show:projects": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx show projects",
    "build": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t build --projects=auth-service,admin-service,user-service,catalog-service,inventory-service,vendor-service,payment-service,order-service",
    "build:all": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx run-many -t build --projects=auth-service,admin-service,user-service,catalog-service,inventory-service,vendor-service,payment-service,order-service",
    "build:auth": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build auth-service",
    "build:admin": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build admin-service",
    "build:user": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build user-service",
    "build:catalog": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build catalog-service",
    "build:inventory": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build inventory-service",
    "build:vendor": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build vendor-service",
    "build:payment": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build payment-service",
    "build:order": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx build order-service",
    "audit:access-control": "./scripts/audit/access-control-check.sh",
    "ops:db:backup": "./scripts/ops/db-backup.sh",
    "ops:db:restore": "./scripts/ops/db-restore.sh",
    "ops:dlq:replay": "node ./scripts/ops/replay-dlq.js",
    "load:inventory": "k6 run ./scripts/load/inventory-reservation.k6.js",
    "load:orders": "k6 run ./scripts/load/order-checkout.k6.js",
    "load:payments": "k6 run ./scripts/load/payment-intents.k6.js",
    "migration:run:auth": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/auth-service/src/data-source.ts",
    "migration:run:admin": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/admin-service/src/data-source.ts",
    "migration:run:user": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/user-service/src/data-source.ts",
    "migration:run:vendor": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/vendor-service/src/data-source.ts",
    "migration:run:catalog": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/catalog-service/src/data-source.ts",
    "migration:run:inventory": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/inventory-service/src/data-source.ts",
    "migration:run:order": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/order-service/src/data-source.ts",
    "migration:run:payment": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d apps/payment-service/src/data-source.ts",
    "migration:revert:auth": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/auth-service/src/data-source.ts",
    "migration:revert:admin": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/admin-service/src/data-source.ts",
    "migration:revert:user": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/user-service/src/data-source.ts",
    "migration:revert:vendor": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/vendor-service/src/data-source.ts",
    "migration:revert:catalog": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/catalog-service/src/data-source.ts",
    "migration:revert:inventory": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/inventory-service/src/data-source.ts",
    "migration:revert:order": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/order-service/src/data-source.ts",
    "migration:revert:payment": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert -d apps/payment-service/src/data-source.ts",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\"",
    "start:auth": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve auth-service",
    "start:admin": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve admin-service",
    "start:user": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve user-service",
    "start:catalog": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve catalog-service",
    "start:inventory": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve inventory-service",
    "start:vendor": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve vendor-service",
    "start:payment": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve payment-service",
    "start:order": "NX_DAEMON=false NX_ISOLATE_PLUGINS=false nx serve order-service",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand"
  },
  "dependencies": {
    "@golevelup/nestjs-stripe": "^1.1.1",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.1.5",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/amqplib": "^0.10.8",
    "@types/cache-manager": "^4.0.6",
    "amqplib": "^1.0.3",
    "bcrypt": "^5.1.1",
    "cache-manager": "^7.2.7",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.2.3",
    "joi": "^18.0.2",
    "mongoose": "^8.14.1",
    "passport-jwt": "^4.0.1",
    "pg": "^8.15.6",
    "raw-body": "^3.0.2",
    "redis": "^4.7.1",
    "reflect-metadata": "^0.2.2",
    "request-ip": "^3.3.0",
    "rxjs": "^7.8.1",
    "stripe": "^20.1.2",
    "typeorm": "^0.3.22"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/request-ip": "^0.0.41",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "nx": "^22.6.4",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@ecommerce/auth$": "<rootDir>/libs/auth/src",
      "^@ecommerce/contracts$": "<rootDir>/libs/contracts/src",
      "^@ecommerce/common-bootstrap$": "<rootDir>/libs/common-bootstrap/src",
      "^@ecommerce/common-config$": "<rootDir>/libs/common-config/src",
      "^@ecommerce/db$": "<rootDir>/libs/db/src",
      "^@ecommerce/shared/(.*)$": "<rootDir>/libs/shared/src/$1",
      "^src/common/(.*)$": "<rootDir>/libs/shared/src/common/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
