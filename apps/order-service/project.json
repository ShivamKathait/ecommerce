{
  "name": "order-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/order-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build order-service"
      },
      "outputs": ["{workspaceRoot}/dist/apps/order-service"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start order-service --watch"
      }
    },
    "serve:prod": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/apps/order-service/main"
      }
    }
  },
  "tags": ["type:app", "scope:order"]
}

