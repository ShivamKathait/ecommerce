{
  "name": "auth-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/auth-service/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest build auth-service"
      },
      "outputs": ["{workspaceRoot}/dist/apps/auth-service"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nest start auth-service --watch"
      }
    },
    "serve:prod": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "node dist/apps/auth-service/main"
      }
    }
  },
  "tags": ["type:app", "scope:auth"]
}
